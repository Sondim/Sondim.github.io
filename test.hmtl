<section id="flame-section" class="max-w-4xl mx-auto px-6 py-24 text-center">
    <h2 class="text-orange-500 font-mono text-xs uppercase tracking-[0.3em] mb-4 font-bold">// Burnout_Threshold_Monitor</h2>
    <h3 class="text-3xl md:text-5xl font-black text-white mb-10 leading-tight">Are you burning bright or <span class="text-orange-700">burning out</span>?</h3>
    
    <div class="relative flex justify-center items-center mb-10">
        <canvas id="c" width="180" height="180" class="bg-zinc-950 rounded-full border-4 border-white/5 shadow-[0_0_50px_rgba(249,115,22,0.2)]"></canvas>
    </div>

    <div class="max-w-sm mx-auto space-y-6">
        <div class="flex justify-between text-xs font-mono text-zinc-500 uppercase tracking-widest">
            <span>Core Temperature:</span>
            <span id="temp-val" class="text-orange-500">Normal</span>
        </div>
        <input type="range" min="0.1" max="3" step="0.1" value="1" id="fire-slider" class="w-full" oninput="updateFire()">
        <p class="text-zinc-500 text-xs italic">Low intensity mimics "Freeze Response" (stagnation). High intensity mimics "Crisis Mode" (burnout).</p>
    </div>
</section>

<script>
    const canvas = document.getElementById('c');
    const ctx = canvas.getContext('2d');
    let particles = [];
    let intensity = 1.0;

    class Particle {
        constructor() {
            this.reset();
        }
        reset() {
            this.x = canvas.width / 2 + (Math.random() * 20 - 10);
            this.y = canvas.height - 20;
            this.vx = (Math.random() * 2 - 1) * intensity;
            this.vy = (Math.random() * -3 - 2) * intensity;
            this.life = Math.random() * 20 + 10;
            this.opacity = 1;
            this.size = Math.random() * 5 + 2;
        }
        update() {
            this.x += this.vx;
            this.y += this.vy;
            this.life -= 0.5 / intensity;
            this.opacity = this.life / 20;
            if (this.life <= 0) this.reset();
        }
        draw() {
            // Color shifts from White (hot) -> Orange -> Red (cool)
            const r = 255;
            const g = Math.min(255, 50 + (this.life * 15 * intensity));
            const b = Math.min(255, this.life * 5);
            ctx.fillStyle = `rgba(${r}, ${g}, ${b}, ${this.opacity})`;
            ctx.beginPath();
            ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
            ctx.fill();
        }
    }

    function initFire() {
        particles = [];
        for (let i = 0; i < 100; i++) particles.push(new Particle());
        animateFire();
    }

    function updateFire() {
        intensity = document.getElementById('fire-slider').value;
        const label = document.getElementById('temp-val');
        if (intensity < 0.8) label.innerText = "Snuffed";
        else if (intensity > 2.2) label.innerText = "OVERHEAT";
        else label.innerText = "Stable";
    }

    function animateFire() {
        // Subtle tail effect (don't clear fully)
        ctx.fillStyle = 'rgba(9, 9, 11, 0.2)'; 
        ctx.fillRect(0, 0, canvas.width, canvas.height);
        
        // Blur effect for "glow"
        ctx.globalCompositeOperation = 'lighter';
        particles.forEach(p => {
            p.update();
            p.draw();
        });
        ctx.globalCompositeOperation = 'source-over';
        requestAnimationFrame(animateFire);
    }

    window.addEventListener('DOMContentLoaded', initFire);
</script>
